{
  "name": "altara",
  "version": "0.1.0",
  "private": true,
  "description": "Altara — Plataforma de Adoção de IA pra mid-market BR",
  "scripts": {
    "dev": "pnpm --filter @altara/web dev",
    "build": "pnpm --filter @altara/web build",
    "start": "pnpm --filter @altara/web start",
    "lint": "pnpm --filter @altara/web lint",
    "typecheck": "pnpm --filter @altara/web typecheck",
    "test": "pnpm --filter @altara/web test",
    "db:generate": "pnpm --filter @altara/web db:generate",
    "db:push": "pnpm --filter @altara/web db:push",
    "db:studio": "pnpm --filter @altara/web db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
