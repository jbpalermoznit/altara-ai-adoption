# =====================================================================
# Altara — variáveis de ambiente
# Copie pra .env.local (não commitar) e preencha com seus valores reais.
# =====================================================================

# -----------------------------
# Supabase (banco + auth + storage)
# -----------------------------
# Crie em https://supabase.com → New Project → região São Paulo (sa-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Connection string pro Drizzle (Settings → Database → Connection string → URI)
# Usar pooler (porta 6543) pra serverless, direta (porta 5432) pra migrations
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# -----------------------------
# LLM (Anthropic principal, OpenAI fallback)
# -----------------------------
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# https://platform.openai.com
OPENAI_API_KEY=sk-...

# -----------------------------
# E-mail (Resend)
# -----------------------------
# https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Altara <oi@altara.com.br>"

# -----------------------------
# Observabilidade
# -----------------------------
# https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=altara-web

# https://posthog.com (Region: EU ou US)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------
# App
# -----------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Cron secret (gera com: openssl rand -hex 32)
CRON_SECRET=
